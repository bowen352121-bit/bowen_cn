rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /guestbook_comments/{commentId} {
      // 仅已登录（Google）用户可读写
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 500000;

      allow update: if false;

      // 仅站长可删评（邮箱须与 景教/firebase-config.js 中 guestbookAdmin 一致）
      allow delete: if request.auth != null
        && request.auth.token.email == 'bowen352121@gmail.com';
    }

    match /cafe_posts/{postId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.author is string
        && request.resource.data.author.size() > 0
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 80
        && request.resource.data.excerpt is string
        && request.resource.data.excerpt.size() > 0
        && request.resource.data.excerpt.size() <= 2000;

      allow update, delete: if false;
    }
  }
}
